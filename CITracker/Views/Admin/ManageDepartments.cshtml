@using CITracker.Resources
@using System.Reflection
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory LocalizerFactory
@model Shared.ViewModels.OperationLocationVM

@{
    ViewData["Title"] = "CI Tracker";
    ViewData["Base"] = "LocationManagement";
    ViewData["Active"] = "ManageDepartments";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}
@{
    var localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
}

<!--APP-CONTENT START-->
<div class="main-content app-content">
    <div class="container-fluid">
        <!-- Page Header -->
        <div class="d-md-flex d-block align-items-center justify-content-between page-header-breadcrumb">
            <div>
                <h2 class="main-content-title fs-24 mb-1">@SharedResource.ManageFacilityDepartments</h2>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="javascript:void(0)">@SharedResource.Administration</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@SharedResource.ManageFacilityDepartments</li>
                </ol>
            </div>
        </div>
        <!-- Page Header Close -->
        <!-- Page Header Close -->
        <div id="project_info" class="row row-sm">
            @if (Model.StatusCode > 0)
            {
                if (Model.StatusCode == 200)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <strong>@localizer[Model.Message]</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"><i class="bi bi-x"></i></button>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>@localizer[Model.Message]</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"><i class="bi bi-x"></i></button>
                    </div>
                }
            }
            <div class="col-lg-4 col-xl-4 col-md-6 col-sm-12">
                <div class="card custom-card">
                    <div class="card-header justify-content-between">
                        <div class="card-title"> @SharedResource.AddADepartment </div>
                    </div>
                    @using (Html.BeginForm("AddDepartment", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="card-body">
                            <div class="row gy-4">
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectACountry<span style="color:red">*</span></label>
                                    <select class="form-control" name="country" id="country" onchange="onCountryChange(this, 'facilityA')" required>
                                        <option selected disabled value="0">@SharedResource.SelectACountry</option>
                                        @if (Model.Country != null)
                                        {
                                            if (Model.Country.Any())
                                            {
                                                foreach (var country in Model.Country)
                                                {
                                                    <option value="@country.Id">@country.Country</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectAFacility<span style="color:red">*</span></label>
                                    <select class="form-control" name="facilityA" id="facilityA" required>
                                        <option disabled>@SharedResource.SelectAFacility</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <p class="mb-2 fw-medium">
                                        @SharedResource.Department <span style="color:red">*</span>
                                        <a href="javascript:void(0);" data-bs-toggle="tooltip" data-bs-custom-class="tooltip-primary" class="text-primary" title="@SharedResource.Department"> <i class="fe fe-info"></i></a>
                                    </p>
                                    <input type="text" class="form-control country-input" name="department" id="department" placeholder="@SharedResource.NameOfDepartment" required>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-top-card">
                            <button class="btn btn-success shadow-success">@SharedResource.Submit</button>
                        </div>
                    }
                    
                </div>
            </div>
            <div class="col-lg-4 col-xl-4 col-md-6 col-sm-12">
                <div class="card custom-card">
                    <div class="card-header justify-content-between">
                        <div class="card-title"> @SharedResource.RenameADepartment </div>
                    </div>
                    @using (Html.BeginForm("RenameDepartment", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="card-body">
                            <div class="row gy-4">
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectACountry<span style="color:red">*</span></label>
                                    <select class="form-control" name="countryR" id="countryR" onchange="onCountryChange(this, 'facilityR')" required>
                                        <option selected disabled value="0">@SharedResource.SelectACountry</option>
                                        @if (Model.Country != null)
                                        {
                                            if (Model.Country.Any())
                                            {
                                                foreach (var country in Model.Country)
                                                {
                                                    <option value="@country.Id">@country.Country</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectAFacility<span style="color:red">*</span></label>
                                    <select class="form-control" name="facilityR" id="facilityR" onchange="onFacilityChange(this, 'departmentR')" required>
                                        <option selected disabled value="0">@SharedResource.SelectAFacility</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectADepartment<span style="color:red">*</span></label>
                                    <select class="form-control" name="departmentR" id="departmentR" onchange="setInputFromSelect(this, 'departmentN')" required>
                                        <option selected disabled value="0">@SharedResource.SelectADepartment</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <p class="mb-2 fw-medium">
                                        @SharedResource.Department <span style="color:red">*</span>
                                        <a href="javascript:void(0);" data-bs-toggle="tooltip" data-bs-custom-class="tooltip-primary" class="text-primary" title="@SharedResource.Department"> <i class="fe fe-info"></i></a>
                                    </p>
                                    <input type="text" class="form-control country-input" name="departmentN" id="departmentN" placeholder="@SharedResource.NameOfDepartment" required>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-top-card">
                            <button class="btn btn-success shadow-success">@SharedResource.Submit</button>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-4 col-xl-4 col-md-6 col-sm-12">
                <div class="card custom-card">
                    <div class="card-header justify-content-between">
                        <div class="card-title"> @SharedResource.DeleteADepartment </div>
                    </div>
                    @using (Html.BeginForm("DeleteDepartment", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="card-body">
                            <div class="row gy-4">
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectACountry<span style="color:red">*</span></label>
                                    <select class="form-control" name="countryD" id="countryD" onchange="onCountryChange(this, 'facilityD')" required>
                                        <option selected disabled value="0">@SharedResource.SelectACountry</option>
                                        @if (Model.Country != null)
                                        {
                                            if (Model.Country.Any())
                                            {
                                                foreach (var country in Model.Country)
                                                {
                                                    <option value="@country.Id">@country.Country</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectAFacility<span style="color:red">*</span></label>
                                    <select class="form-control" name="facilityD" id="facilityD" onchange="onFacilityChange(this, 'departmentD')" required>
                                        <option selected disabled value="0">@SharedResource.SelectAFacility</option>
                                    </select>
                                </div>
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectADepartment<span style="color:red">*</span></label>
                                    <select class="form-control" name="departmentD" id="departmentD" required>
                                        <option selected disabled value="0">@SharedResource.SelectADepartment</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-top-card">
                            <button class="btn btn-success shadow-success">@SharedResource.Submit</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const facilities = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Facility))
    const departments = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Department))
    const resources = {
        facilityDefault: '@SharedResource.SelectAFacility',
        departmentDefault: '@SharedResource.SelectADepartment',
        invalidDepart: '@SharedResource.InvalidDepartment'
    }

    function onCountryChange(selectEl, targetInputId) {
        const countryId = parseInt(selectEl.value);
        const locationSelect = document.getElementById(targetInputId);

        // Clear existing options
        locationSelect.innerHTML = '<option disabled>'+resources.facilityDefault+'</option>';

        if (isNaN(countryId)) return;

        const filtered = facilities.filter(l => l.OrganizationCountryId === countryId);

        filtered.forEach(item => {
            const option = document.createElement('option');
            option.value = item.Id;
            option.textContent = item.Facility;
            locationSelect.appendChild(option);
        });
    }

    function onFacilityChange(selectEl, targetInputId) {
        const facilityId = parseInt(selectEl.value);
        const locationSelect = document.getElementById(targetInputId);

        // Clear existing options
        locationSelect.innerHTML = '<option disabled>'+resources.departmentDefault+'</option>';

        if (isNaN(facilityId)) return;

        const filtered = departments.filter(l => l.OrganizationFacilityId === facilityId);

        filtered.forEach(item => {
            const option = document.createElement('option');
            option.value = item.Id;
            option.textContent = item.Department;
            locationSelect.appendChild(option);
        });
    }

    document.addEventListener("DOMContentLoaded", function () {

        const countryRegex = /^[\p{L}\s\-.'()]+$/u;

        const inputs = document.querySelectorAll(".country-input");

        inputs.forEach(function (input) {

            input.addEventListener("input", function () {

                if (this.value === "") {
                    this.setCustomValidity("");
                    return;
                }

                if (!countryRegex.test(this.value)) {
                    this.setCustomValidity(resources.invalidDepart);
                } else {
                    this.setCustomValidity("");
                }
            });

        });

    });

    function setInputFromSelect(selectEl, targetInputId) {
      if (!selectEl || !targetInputId) return;

      const input = document.getElementById(targetInputId);
      if (!input) return;

      const selectedOption = selectEl.options[selectEl.selectedIndex];
      input.value = selectedOption ? selectedOption.text.trim() : '';
    }
</script>
