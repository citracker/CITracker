<script>
    const resources = {
        cancelSub: '@SharedResource.AreYouSureYouWantToCancelYourSubscription',
        cancelSubResp: '@SharedResource.SubscriptionCancellationRequestSubmittedSuccessfully',
        someWentWrong: '@SharedResource.SomethingWentWrong'
    }
    function cancelSubscription(sid) {

        if (!confirm(resources.cancelSub)) {
            return;
        }

        console.log(JSON.stringify({ strId: sid }))

        fetch('/Cancel', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify({ StrId: sid })
            })
        .then(res => res.json())
        .then(data => {
            alert(resources.cancelSubResp);
            location.reload();
        })
        .catch(err => {
            console.error(err);
            alert(resources.someWentWrong;
        });

    }


    function upgradeSubscription() {

        fetch('/api/subscription/upgrade', {
            method: 'POST'
        })
        .then(res => res.json())
        .then(data => {

            // Redirect to Stripe checkout
            window.location.href = data.checkoutUrl;

        });

    }
</script>