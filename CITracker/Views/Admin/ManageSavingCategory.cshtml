@using CITracker.Resources
@using System.Reflection
@using Microsoft.Extensions.Localization
@inject IStringLocalizerFactory LocalizerFactory
@model Shared.DTO.ResponseHandler<Shared.Models.OrganizationSoftSaving>

@{
    ViewData["Title"] = "CI Tracker";
    ViewData["Base"] = "ToolManagement";
    ViewData["Active"] = "ManageSavingCategory";
    Layout = "~/Views/Shared/_MainLayout.cshtml";
}
@{
    var localizer = LocalizerFactory.Create("SharedResource", Assembly.GetExecutingAssembly().GetName().Name);
}

<!--APP-CONTENT START-->
<div class="main-content app-content">
    <div class="container-fluid">
        <!-- Page Header -->
        <div class="d-md-flex d-block align-items-center justify-content-between page-header-breadcrumb">
            <div>
                <h2 class="main-content-title fs-24 mb-1">@SharedResource.ToolManagement</h2>
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="javascript:void(0)">@SharedResource.Administration</a></li>
                    <li class="breadcrumb-item active" aria-current="page">@SharedResource.ToolManagement</li>
                </ol>
            </div>
        </div>
        <!-- Page Header Close -->
        <div id="project_info" class="row row-sm">
            @if (Model.StatusCode > 0)
            {
                if (Model.StatusCode == 200)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <strong>@localizer[Model.Message]</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"><i class="bi bi-x"></i></button>
                    </div>
                }
                else
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <strong>@localizer[Model.Message]</strong>
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"><i class="bi bi-x"></i></button>
                    </div>
                }
            }
            <div class="col-lg-4 col-xl-4 col-md-6 col-sm-12">
                <div class="card custom-card">
                    <div class="card-header justify-content-between">
                        <div class="card-title"> @SharedResource.AddSoftSavingCategory </div>
                    </div>
                    @using (Html.BeginForm("AddSoftSavingCategory", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        <div class="card-body">
                            <div class="row gy-4">
                                <div class="col-12">
                                    <p class="mb-2 fw-medium">
                                        @SharedResource.SoftSavingCategory <span style="color:red">*</span>
                                        <a href="javascript:void(0);" data-bs-toggle="tooltip" data-bs-custom-class="tooltip-primary" class="text-primary"> <i class="fe fe-info"></i></a>
                                    </p>
                                    <input type="text" class="form-control mt-3 mb-3" id="ssc" name="ssc" placeholder="@SharedResource.CategoryEgTimeSpaceQuality" required>
                                    <input type="text" class="form-control mt-3 mb-3" id="ssu" name="ssu" placeholder="@SharedResource.UnitOfMeasurement" required>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-top-card">
                            <button type="submit" class="btn btn-success shadow-success">@SharedResource.Submit</button>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-4 col-xl-4 col-md-6 col-sm-12">
                <div class="card custom-card">
                    <div class="card-header justify-content-between">
                        <div class="card-title"> @SharedResource.RenameASoftSavingCategory </div>
                    </div>
                    @using (Html.BeginForm("ModifySoftSavingCategory", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="card-body">
                            <div class="row gy-4">
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectASoftSavingCategory<span style="color:red">*</span></label>
                                    <select class="form-control" name="sss" id="sss" onchange="onCategoryChange(this, 'sscM', 'ssuM')" required>
                                        <option disabled>@SharedResource.SelectASoftSavingCategory</option>
                                        @if (Model.Result != null)
                                        {
                                            if (Model.Result.Any())
                                            {
                                                foreach (var i in Model.Result)
                                                {
                                                    <option value="@i.Id">@i.Category</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-12">
                                    <p class="mb-2 fw-medium">
                                        @SharedResource.SoftSavingCategoryDetails <span style="color:red">*</span>
                                        <a href="javascript:void(0);" data-bs-toggle="tooltip" data-bs-custom-class="tooltip-primary" class="text-primary"> <i class="fe fe-info"></i></a>
                                    </p>
                                    <input type="text" class="form-control mt-3 mb-3 country-input" id="sscM" name="sscM" placeholder="@SharedResource.CategoryEgTimeSpaceQuality" required>
                                    <input type="text" class="form-control mt-3 mb-3 country-input" id="ssuM" name="ssuM" placeholder="@SharedResource.UnitOfMeasurement" required>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-top-card">
                            <button type="submit" class="btn btn-success shadow-success">@SharedResource.Submit</button>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-4 col-xl-4 col-md-6 col-sm-12">
                <div class="card custom-card">
                    <div class="card-header justify-content-between">
                        <div class="card-title"> @SharedResource.DeleteASoftSavingCategory </div>
                    </div>
                    @using (Html.BeginForm("DeleteSoftSavingCategory", "Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()

                        <div class="card-body">
                            <div class="row gy-4">
                                <div class="col-12">
                                    <label for="input-text" class="form-label">@SharedResource.SelectASoftSavingCategory<span style="color:red">*</span></label>
                                    <select class="form-control" name="sssD" id="sssD">
                                        <option disabled>@SharedResource.SelectASoftSavingCategory</option>
                                        @if (Model.Result != null)
                                        {
                                            if (Model.Result.Any())
                                            {
                                                foreach (var i in Model.Result)
                                                {
                                                    <option value="@i.Id">@i.Category</option>
                                                }
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer border-top-card">
                            <button type="submit" class="btn btn-success shadow-success">@SharedResource.Submit</button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
<!--APP-CONTENT CLOSE-->
<script>
    const categories = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Result));
    const resources = {
        invalidSSC: '@SharedResource.InvalidSavingCategoryName'
    }

    document.addEventListener("DOMContentLoaded", function () {

        const countryRegex = /^[\p{L}\s\-.'()]+$/u;

        const inputs = document.querySelectorAll(".country-input");

        inputs.forEach(function (input) {

            input.addEventListener("input", function () {

                if (this.value === "") {
                    this.setCustomValidity("");
                    return;
                }

                if (!countryRegex.test(this.value)) {
                    this.setCustomValidity(resources.invalidSSC);
                } else {
                    this.setCustomValidity("");
                }
            });

        });

    });

    function onCategoryChange(selectEl, ssc, ssu) {
        const catId = parseInt(selectEl.value);
        const sscInp = document.getElementById(ssc);
        const ssuInp = document.getElementById(ssu);


        if (isNaN(catId)) return;

        const filtered = categories.filter(l => l.Id === catId);

        filtered.forEach(item => {
           sscInp.value = item.Category;
           ssuInp.value = item.Unit;
        });
    }
</script>