                    </h2>
                    <div id="collapseFilter" class="accordion-collapse collapse" aria-labelledby="filterHeader" data-bs-parent="#filterAccord">
                        <div class="accordion-body">
                            <div id="filterForm">
                                <div class="row gy-4">
                                    <div class="col-xl-3 col-lg-3 col-md-3 col-sm-12">
                                        <div class="form-group">
                                            <div class="input-group">
                                                <div class="input-group-text text-muted"> <i class="ri-calendar-line"></i> </div>
                                                <input type="text" class="form-control flatpickr-input active" id="startdate" name="startdate" placeholder="@SharedResource.StartDate" readonly="readonly">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-xl-3 col-lg-3 col-md-3 col-sm-12">
                                        <div class="form-group">
                                            <div class="input-group">
                                                <div class="input-group-text text-muted"> <i class="ri-calendar-line"></i> </div>
                                                <input type="text" class="form-control flatpickr-input active" id="enddate" name="enddate" placeholder="@SharedResource.EndDate" readonly="readonly">
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-xl-3 col-lg-3 col-md-3 col-sm-12">
                                        <select class="form-control" id="priority" name="priority">
                                            <option selected disabled value="">@SharedResource.SelectPriority</option>
                                            <option value="All">All</option>
                                            <option value="High">High</option>
                                            <option value="Medium">Medium</option>
                                            <option value="Low">Low</option>
                                        </select>
                                    </div>
                                    <div class="col-xl-3 col-lg-3 col-md-3 col-sm-12">
                                        <select class="form-control" name="users" id="users">
                                            <option selected disabled value="">@SharedResource.SelectFacilitatorSponsor</option>
                                            <option value="All">All</option>
                                            @if (Model.OrganizationUser != null)
                                            {
                                                if (Model.OrganizationUser.Any())
                                                {
                                                    foreach (var i in Model.OrganizationUser)
                                                    {
                                                        <option value="@i.Id">@i.Name</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-xl-3 col-lg-3 col-md-3 col-sm-12">
                                        <select class="form-control" id="country" name="country">
                                            <option selected disabled value="">@SharedResource.SelectCountry</option>
                                            @if (Model.OrganizationCountry != null)
                                            {
                                                if (Model.OrganizationCountry.Any())
                                                {
                                                    foreach (var country in Model.OrganizationCountry)
                                                    {
                                                        <option value="@country.Id">@country.Country</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-xl-3 col-lg-3 col-md-3 col-sm-12">
                                        <select class="form-control" id="department" name="department">
                                            <option selected disabled value="">@SharedResource.SelectGroupFunction</option>
                                            @if (Model.OrganizationDepartment != null)
                                            {
                                                if (Model.OrganizationDepartment.Any())
