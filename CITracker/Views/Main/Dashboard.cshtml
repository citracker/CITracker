<script>
    let currentFilters = {};
    const resources = {
        methodology: '@SharedResource.Methodology',
        noData: '@SharedResource.NoDataAvailable',
        projStat: '@SharedResource.ProjectStatus',
        certification: '@SharedResource.Certification',
        savingCat: '@SharedResource.SavingsCategory',
        monthlyProj: '@SharedResource.MonthlyProjects',
        monthlyProjStat: '@SharedResource.MonthlyProjectsStatus',
        monthlyProjPerPhase: '@SharedResource.MonthlyProjectsPerPhase',
        monthlyProjPerDept: '@SharedResource.MonthlyProjectsPerDepartment',
        monthlySavings: '@SharedResource.MonthlySavings',
        facProj: '@SharedResource.FacilitatorsProjects',
        errorOccured: '@SharedResource.AnErrorOccurred'
    }

    $(document).ready(function () {
        const endPicker = flatpickr("#enddate", {
            dateFormat: "Y-m-d"
        });

        const startPicker = flatpickr("#startdate", {
            dateFormat: "Y-m-d"
        });

        // Apply filter button click handler
        $('#applyFilterBtn').click(function() {
            applyFilters();
        });

        // Clear filter button click handler
        $('#clearFilterBtn').click(function() {
            clearFilters();
        });

        // Load default data on page load
        loadAllCharts();
    });

    function formatDateToMMDDYYYY(dateString) {
        const date = new Date(dateString);

        // Handle invalid dates
        if (isNaN(date.getTime())) {
            console.log('Invalid date:', dateString);
            return '';
        }

        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        const year = date.getFullYear();

        return `${month}/${day}/${year}`;
    }

    // Function to collect filter values
    function getFilterValues() {
        const filters = {};

        const startDate = $('#startdate').val();
        const endDate = $('#enddate').val();
        const priority = $('#priority').val();
        const users = $('#users').val();
        const country = $('#country').val();
        const department = $('#department').val();
        const status = $('#status').val();

        if (startDate) filters.startdate = startDate;
        if (endDate) filters.enddate = endDate;
        if (priority) filters.priority = priority;
        if (users) filters.users = users;
        if (country) filters.country = country;
        if (department) filters.department = department;
        if (status) filters.status = status;

        console.log("Filters:", filters);

        return filters;
    }

    // Function to build query string from filters
    function buildQueryString(filters) {
        const params = new URLSearchParams();
        Object.keys(filters).forEach(key => {
            if (filters[key] && filters[key] !== 'All') {
                params.append(key, filters[key]);
            }
        });
        const queryString = params.toString();
        return queryString ? `?${queryString}` : '';
    }

    // Function to apply filters and reload all charts
    function applyFilters() {
        currentFilters = getFilterValues();
        loadAllCharts();
    }

    // Function to clear all filters
    function clearFilters() {
        // Reset all form fields
        $('#startdate').val('');
        $('#enddate').val('');
        $('#priority').val('');
        $('#users').val('');
        $('#country').val('');
        $('#department').val('');
        $('#status').val('');

        // Clear current filters and load default data
        currentFilters = {};
        loadAllCharts();
    }

    // Function to load all charts with current filters
    async function loadAllCharts() {
        // Show loading states
        showLoadingStates();

        // Load all charts in parallel
        await Promise.all([
            loadData(),
            loadChartData(),
            loadChartData1(),
            loadPolarData(),
            loadChartData2(),
            loadBarChartData(),
            loadBarChartData2(),
            loadCompletedProjectsData(),
            loadBarChartData3(),
            loadDepartmentData(),
            loadPhaseData()
        ]);

        // Hide loading states
        hideLoadingStates();
    }

    // Helper functions for loading states
    function showLoadingStates() {
        // Add loading indicators if needed
        $('.chart-container').addClass('loading');
    }

    function hideLoadingStates() {
        $('.chart-container').removeClass('loading');
    }



    async function loadData() {
        try {
            const queryString = buildQueryString(currentFilters);
            const response = await fetch('/DashboardAnalytics' + queryString);

            if (!response.ok) {
                prepUI();
                return;
            }

            let result = [];

            try {
                result = await response.json();
            } catch {
                prepUI();
                return;
            }

            if (!result || result.length === 0) {
                prepUI();
                return;
            }

            prepUI(result);

        } catch (error) {
            prepUI();
        }
    }
    loadData();





    const chartDom = document.getElementById('projCountbyMethodology');
    const myChart = echarts.init(chartDom);

    const option = {
        title: {
            text: resources.methodology+' #',
            top: 'top'
        },
        tooltip: {
            trigger: 'item'
        },
        legend: {
            orient: 'horizontal',
            bottom: 'bottom'
        },
        emphasis: {
            itemStyle: {
