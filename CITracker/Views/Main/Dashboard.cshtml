                                        <button type="button" id="applyFilterBtn" class="btn btn-success me-5">@SharedResource.Submit</button>
                                        <button type="button" id="clearFilterBtn" class="btn btn-outline-dark btn-wave">@SharedResource.Clear</button>
                                    </div>
