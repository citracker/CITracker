    function prepUI(list){
        const container = document.getElementById('totalsavings');
        const container1 = document.getElementById('projectcount');
        const container2 = document.getElementById('audited');
        const container3 = document.getElementById('totalexpectedsavings');
        container.innerHTML = '';
        container1.innerHTML = '';
        container2.innerHTML = '';
        container3.innerHTML = '';

        if (!list || list.length === 0) {
            return;
        }

        list.forEach(item => {
            const div = document.createElement('div');
            div.className = 'card-item-stat';
            div.innerHTML = `
                <h4 class="fw-bold">${item.Currency} ${Number(item.TotalHardSavings).toLocaleString('en-US', {
                    minimumFractionDigits: 2,
                    maximumFractionDigits: 2
                })}</h4>`;

            const div1 = document.createElement('div');
            div1.className = 'card-item-stat';
            div1.innerHTML = `
                <h4 class="fw-bold">${item.ProjectCount}</h4>
            `;

            const div2 = document.createElement('div');
            div2.className = 'card-item-stat';
            div2.innerHTML = `
                <h4 class="fw-bold">${item.Audited}</h4>
            `;

            const div3 = document.createElement('div');
            div3.className = 'card-item-stat';
            div3.innerHTML = `
                <h4 class="fw-bold">${item.Currency} ${Number(item.TotalExpectedRevenue).toLocaleString('en-US', {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            })}</h4>`;

            container.appendChild(div);
            container1.appendChild(div1);
            container2.appendChild(div2);
            container3.appendChild(div3);
        });
    }



    function showNoData(chart, message) {
        chart.clear();
        chart.setOption({
            title: {
                text: message,
                left: 'center',
                top: 'center',
                textStyle: {
                    fontSize: 18,
                    fontWeight: 'normal',
                    color: '#999'
                }
            }
        });
    }

    function showNoDataCjs(chart, message) {

        // Clear chart data
        chart.data.labels = [];
        chart.data.datasets.forEach(ds => ds.data = []);

        // Remove legend (optional)
        chart.options.plugins.legend.display = false;

        // Add centered title message
        chart.options.plugins.title.display = true;
            chart.options.plugins.title = {
            display: true,
            text: message,
            align: 'center',
            padding: 20,
            font: {
                size: 16,
                weight: 'normal'
            }
        };

        chart.update();
    }


